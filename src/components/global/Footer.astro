---
import { siteConfig } from '../../data/siteConfig';
---

<!-- CTA Bar - Clean, lighter -->
<section class="relative bg-accent-50 py-12 md:py-16 overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <h2 class="font-heading font-black text-2xl md:text-3xl lg:text-4xl text-primary-500 leading-tight">
          Vragen? We helpen u <span class="text-accent-400">graag!</span>
        </h2>
        <p class="text-secondary-400 text-base mt-2 max-w-lg">
          Neem gerust contact met ons op voor een vrijblijvende offerte of advies over uw project.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
        <a href="/contact/" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-8 py-4 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Neem contact op
        </a>
        <a href={`tel:${siteConfig.contact.phone}`} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border-2 border-primary-500/20 hover:border-accent-400 text-primary-500 hover:text-accent-500 px-8 py-4 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          {siteConfig.contact.phone}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="bg-primary-500 text-primary-100 relative">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Company Info -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <img
            src="/fotos-jd-infra/fotos jd infra/logo_64d0900b.svg"
            alt="JD Infra"
            class="w-10 h-10"
            width="40"
            height="40"
          />
          <span class="font-heading text-white text-xl font-bold">{siteConfig.shortName}</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed mb-4">
          {siteConfig.tagline}
        </p>
        <p class="text-white/30 text-sm">
          Sinds {siteConfig.founded} actief in heel Zeeland.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-heading text-white text-sm font-bold mb-5 uppercase tracking-[0.2em]">Navigatie</h3>
        <ul class="space-y-3">
          {siteConfig.navigation.filter(n => !('children' in n)).map((item) => (
            <li>
              <a href={item.href} class="text-white/50 hover:text-accent-400 transition-colors text-sm font-heading tracking-wide">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Diensten -->
      <div>
        <h3 class="font-heading text-white text-sm font-bold mb-5 uppercase tracking-[0.2em]">Diensten</h3>
        <ul class="space-y-3">
          {siteConfig.diensten.map((dienst) => (
            <li>
              <a href={`/diensten/${dienst.slug}/`} class="text-white/50 hover:text-accent-400 transition-colors text-sm font-heading tracking-wide">
                {dienst.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-white text-sm font-bold mb-5 uppercase tracking-[0.2em]">Contact</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-accent-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/50">
              {siteConfig.contact.address}<br />
              {siteConfig.contact.postalCode} {siteConfig.contact.city}
            </span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${siteConfig.contact.phone}`} class="text-white/50 hover:text-accent-400 transition-colors">
              {siteConfig.contact.phone}
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${siteConfig.contact.email}`} class="text-white/50 hover:text-accent-400 transition-colors">
              {siteConfig.contact.email}
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="text-white/30 text-xs font-heading tracking-wide">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Alle rechten voorbehouden.
      </p>
      <p class="text-white/30 text-xs font-heading tracking-wide">
        {siteConfig.contact.city}, {siteConfig.contact.country}
      </p>
    </div>
  </div>

</footer>
