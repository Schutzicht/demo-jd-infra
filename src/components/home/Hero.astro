---
import { siteConfig } from '../../data/siteConfig';
---

<section data-hero class="relative h-[100svh] -mt-20 sm:-mt-24 overflow-hidden flex flex-col justify-end">
  <!-- Animated video background with photo poster fallback -->
  <div class="absolute inset-0">
    <video
      class="w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      poster="/hero/hero-excavator.jpg"
    >
      <source src="/hero/hero-excavator.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-primary-900/90 via-primary-900/40 to-primary-900/20"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary-900/60 via-transparent to-transparent"></div>
  </div>

  <div class="absolute inset-0 grain z-[2]"></div>

  <!-- === MOBILE LAYOUT === -->
  <div class="sm:hidden relative z-10 flex flex-col h-full pt-24 pb-4 px-5">
    <!-- Heading centered vertically -->
    <div class="flex-1 flex flex-col justify-center">
      <span class="inline-flex items-center gap-2.5 mb-4 text-white font-heading font-semibold text-xs uppercase tracking-[0.2em]">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-300 shrink-0"></span>
        Sinds 2006 &middot; Zeeland
      </span>
      <h1>
        <span class="block display-xl text-white">
          Bouwt.<br/>Bestraat.<br/><span class="accent-serif">Verbindt.</span>
        </span>
      </h1>
    </div>

    <!-- Single frosted card at bottom -->
    <div class="bg-white/70 backdrop-blur-2xl rounded-2xl p-5 shadow-2xl border border-white/40">
      <p class="text-secondary-500 text-sm leading-relaxed mb-4">
        Vakkundig infrawerk voor particulieren, bedrijven en overheden in heel Zeeland.
      </p>
      <div class="flex gap-3">
        <a href="/contact/" class="flex-1 inline-flex items-center justify-center gap-2 bg-accent-400 text-white py-3 rounded-full font-heading font-bold text-xs uppercase tracking-wider">
          Offerte aanvragen <span>&rarr;</span>
        </a>
        <a href="/projecten/" class="flex-1 inline-flex items-center justify-center gap-2 border-2 border-primary-500/20 text-primary-500 py-3 rounded-full font-heading font-bold text-xs uppercase tracking-wider">
          Projecten <span>&rarr;</span>
        </a>
      </div>
    </div>
  </div>

  <!-- === DESKTOP LAYOUT === -->
  <div class="hidden sm:flex relative z-10 w-full flex-col justify-end h-full pb-14 lg:pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2.5 mb-6 text-white font-heading font-semibold text-xs uppercase tracking-[0.2em] animate-fade-in" style="animation-delay: 0.15s;">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-300 shrink-0"></span>
          Sinds 2006 &middot; Grond, straat &amp; riool
        </span>

        <h1 class="animate-slide-up" style="animation-delay: 0.3s;">
          <span class="block display-xl text-white" style="font-size: clamp(2.75rem, 5.6vw, 5rem);">
            Bouwt. Bestraat.<br/><span class="accent-serif">Verbindt.</span>
          </span>
        </h1>

        <p class="animate-slide-up text-white/75 text-lg lg:text-xl leading-relaxed mt-6 max-w-xl" style="animation-delay: 0.42s;">
          Vakkundig grond-, straat- en rioleringswerk voor particulieren, bedrijven en overheden in heel Zeeland.
        </p>

        <div class="animate-slide-up flex items-center gap-6 mt-9" style="animation-delay: 0.54s;">
          <a href="/contact/" class="inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-8 py-4 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            Offerte aanvragen &rarr;
          </a>
          <a href="/projecten/" class="group inline-flex items-center gap-2 text-white font-heading font-semibold text-sm uppercase tracking-wider">
            <span class="border-b border-white/40 group-hover:border-accent-300 pb-0.5 transition-colors duration-300">Bekijk projecten</span>
            <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>

        <!-- Integrated stat row -->
        <div class="animate-fade-in flex items-stretch gap-8 lg:gap-10 mt-12 pt-8 border-t border-white/15" style="animation-delay: 0.7s;">
          <div>
            <div class="font-heading font-bold text-2xl lg:text-3xl text-white leading-none" data-counter="2006" data-counter-type="year">2006</div>
            <div class="text-white/55 text-[0.7rem] uppercase tracking-[0.18em] font-heading mt-1.5">Opgericht</div>
          </div>
          <div class="w-px bg-white/15"></div>
          <div>
            <div class="font-heading font-bold text-2xl lg:text-3xl text-white leading-none"><span data-counter="15">15</span><span class="text-accent-300">+</span></div>
            <div class="text-white/55 text-[0.7rem] uppercase tracking-[0.18em] font-heading mt-1.5">Vakmensen</div>
          </div>
          <div class="w-px bg-white/15"></div>
          <div>
            <div class="font-heading font-bold text-2xl lg:text-3xl text-white leading-none"><span data-counter="20">20</span></div>
            <div class="text-white/55 text-[0.7rem] uppercase tracking-[0.18em] font-heading mt-1.5">Jaar ervaring</div>
          </div>
        </div>

        <!-- Vacature-regel -->
        <a href="/vacatures/" class="group animate-fade-in inline-flex items-center gap-2 mt-6 text-white/70 hover:text-white font-heading text-sm transition-colors duration-300" style="animation-delay: 0.82s;">
          <span class="text-white/50">Wij zoeken versterking.</span>
          <span class="inline-flex items-center gap-1.5 text-accent-300 group-hover:text-accent-200 font-semibold">
            Bekijk vacatures <span class="transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </span>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-20 hidden sm:flex flex-col items-center gap-2 text-white/50">
    <span class="text-[10px] uppercase tracking-[0.25em] font-heading">Scroll</span>
    <span class="w-px h-8 bg-gradient-to-b from-white/50 to-transparent"></span>
  </div>
</section>
