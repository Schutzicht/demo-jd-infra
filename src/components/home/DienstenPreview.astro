---
import { siteConfig } from '../../data/siteConfig';

const diensten = siteConfig.diensten;
---

<section class="py-24 sm:py-32 bg-white relative overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Editorial header - asymmetric with section index -->
    <div class="relative flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-14 sm:mb-20">
      <div class="reveal-left relative">
        <span class="section-num absolute -top-12 sm:-top-16 -left-2">01</span>
        <span class="eyebrow mb-5 relative">Wat wij doen</span>
        <h2 class="display-lg text-primary-500 relative">
          Drie disciplines, <span class="accent-serif">één</span> team.
        </h2>
      </div>
      <p class="reveal-right text-secondary-400 max-w-sm text-base sm:text-lg leading-relaxed lg:pb-2">
        Specialist in grond-, straat- en rioleringswerk. Van bouwrijp maken tot de laatste klinker, alles in eigen beheer.
      </p>
    </div>

    <!-- Liquid cards - image fills card with text overlay -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {diensten.map((dienst, i) => (
        <a
          href={`/diensten/${dienst.slug}/`}
          class="reveal group block relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 aspect-[4/5] sm:aspect-[3/4]"
          style={`transition-delay: ${i * 0.15}s;`}
        >
          <!-- Full image -->
          <img
            src={dienst.image}
            alt={dienst.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />

          <!-- Gradient overlay - subtle, just enough for readability -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-all duration-500 group-hover:from-black/80 group-hover:via-black/30"></div>

          <!-- Index label top-left -->
          <span class="absolute top-6 left-6 sm:top-8 sm:left-8 font-display text-white/50 text-sm tracking-widest">0{i + 1}</span>

          <!-- Text overlay at bottom -->
          <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8 flex flex-col justify-end">
            <h3 class="display-md text-white mb-2">
              {dienst.title}
            </h3>

            <p class="text-white/70 text-sm leading-relaxed mb-5 max-h-0 group-hover:max-h-24 overflow-hidden transition-all duration-500 ease-out">
              {dienst.description}
            </p>

            <span class="editorial-link text-white w-fit border-white/40 group-hover:border-accent-400 group-hover:text-accent-400">
              Bekijk dienst
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
