---
import { siteConfig } from '../../data/siteConfig';

const diensten = siteConfig.diensten;
---

<section class="py-24 sm:py-32 bg-white relative overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Section header - two-tone -->
    <div class="text-center mb-16 reveal">
      <h2 class="font-heading font-black text-3xl sm:text-5xl lg:text-6xl text-primary-500 leading-tight mb-4">
        Onze <span class="text-accent-400">Diensten</span>
      </h2>
      <p class="text-secondary-400 max-w-lg mx-auto text-base sm:text-lg leading-relaxed">
        Specialist in grond-, straat- en rioleringswerkzaamheden
      </p>
    </div>

    <!-- Liquid cards - image fills card with text overlay -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {diensten.map((dienst, i) => (
        <a
          href={`/diensten/${dienst.slug}/`}
          class="reveal group block relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 aspect-[4/5] sm:aspect-[3/4]"
          style={`transition-delay: ${i * 0.15}s;`}
        >
          <!-- Full image -->
          <img
            src={dienst.image}
            alt={dienst.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />

          <!-- Gradient overlay - subtle, just enough for readability -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent transition-all duration-500 group-hover:from-black/80 group-hover:via-black/30"></div>

          <!-- Text overlay at bottom -->
          <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8 flex flex-col justify-end">
            <h3 class="font-heading font-bold text-2xl sm:text-3xl text-white mb-2 leading-tight">
              {dienst.title}
            </h3>

            <p class="text-white/70 text-sm leading-relaxed mb-4 max-h-0 group-hover:max-h-24 overflow-hidden transition-all duration-500 ease-out">
              {dienst.description}
            </p>

            <div class="inline-flex items-center gap-2 bg-accent-400 text-white px-5 py-2.5 rounded-full font-heading font-bold text-xs uppercase tracking-wider w-fit opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">
              <span>Meer info</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
