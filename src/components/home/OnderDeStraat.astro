---
// Interactieve branche-feature: realistische straatdoorsnede (Gemini) + klinkerverband-kiezer
// pos = highlight-zone over de doorsnede-foto, in % (top/left/width/height)
const lagen = [
  { id: 'klinkers',   naam: 'Bestrating',      dienst: 'Straatwerk', pos: { top: 14,   left: 0,  width: 100, height: 7 },  tekst: 'De zichtlaag: klinkers of tegels, strak in het door u gekozen verband gelegd en afgetrild.' },
  { id: 'straatzand', naam: 'Straatzand',      dienst: 'Straatwerk', pos: { top: 21,   left: 0,  width: 100, height: 3.5 }, tekst: 'Een dunne, vlak afgereide laag straatzand waarin de klinkers worden gelegd en vastgezet.' },
  { id: 'fundering',  naam: 'Fundering',       dienst: 'Grondwerk',  pos: { top: 24.5, left: 0,  width: 100, height: 27 },  tekst: 'Menggranulaat als draagkrachtige fundering, verdicht zodat de verharding niet verzakt.' },
  { id: 'cunet',      naam: 'Zandbed / cunet', dienst: 'Grondwerk',  pos: { top: 52,   left: 0,  width: 100, height: 34 },  tekst: 'Het uitgegraven cunet, opgevuld met zand. De stabiele basis waar alles op rust.' },
  { id: 'riool',      naam: 'Riolering',       dienst: 'Riolering',  pos: { top: 44,   left: 65, width: 27,  height: 34 },  tekst: 'De rioolbuis op de juiste hoogte en afschot, voor een betrouwbare afvoer van regen- en afvalwater.' },
  { id: 'water',      naam: 'Grondwaterpeil',  dienst: 'Grondwerk',  pos: { top: 86,   left: 0,  width: 100, height: 14 },  tekst: 'Wij houden rekening met de grondwaterstand, zodat de constructie droog en stabiel blijft.' },
];

const verbanden = [
  { id: 'halfsteens', naam: 'Halfsteens',   img: '/images/jd-infra/generated/verband-halfsteens.jpg', tekst: 'Rijen klinkers, telkens een halve steen verspringend. De klassieker voor opritten en paden.' },
  { id: 'blok',       naam: 'Blokverband',  img: '/images/jd-infra/generated/verband-blok.jpg',       tekst: 'Strak boven elkaar gelegd. Rustig en modern, mooi bij bestrating in een patroon.' },
  { id: 'visgraat',   naam: 'Visgraat',     img: '/images/jd-infra/generated/verband-visgraat.jpg',   tekst: 'In elkaar grijpend weefsel. Zeer sterk, ideaal bij zwaarder belaste verharding.' },
  { id: 'keper',      naam: 'Keperverband', img: '/images/jd-infra/generated/verband-keper.jpg',      tekst: 'Visgraat onder 45 graden. Speels en sterk, een echte blikvanger.' },
];
---

<section class="py-24 sm:py-32 bg-slate-50 relative overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="relative mb-14 sm:mb-16 max-w-2xl">
      <span class="section-num absolute -top-12 sm:-top-16 -left-2">03</span>
      <span class="eyebrow mb-5 relative">Onder de straat</span>
      <h2 class="display-lg text-primary-500 relative mb-4">
        Eén straat, <span class="accent-serif">drie</span> ambachten.
      </h2>
      <p class="text-secondary-400 text-base sm:text-lg leading-relaxed">
        Wat u ziet is de klinker. Wat het werk maakt, zit eronder. Klik door de lagen en kies uw eigen straatverband.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">
      <!-- LEFT: Doorsnede -->
      <div class="reveal-left bg-white rounded-2xl shadow-lg border border-secondary-100 p-5 sm:p-7 flex flex-col">
        <p class="font-heading font-bold text-primary-500 text-sm uppercase tracking-wider mb-4">Dwarsdoorsnede</p>

        <div class="relative rounded-xl overflow-hidden select-none">
          <img src="/images/jd-infra/generated/doorsnede-straat.jpg" alt="Realistische dwarsdoorsnede van een straat" class="w-full h-auto block" />
          <!-- highlight zone -->
          <div id="ods-zone" class="absolute rounded-md border-2 border-accent-400 bg-accent-400/15 shadow-[0_0_0_2000px_rgba(0,10,26,0.45)] transition-all duration-300 pointer-events-none opacity-0"></div>
        </div>

        <!-- Legend buttons -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 mt-5">
          {lagen.map((laag, i) => (
            <button
              type="button"
              class="ods-legend text-left px-3 py-2 rounded-lg border border-secondary-200 transition-all duration-200 hover:border-accent-400 cursor-pointer"
              data-target={laag.id}
              data-default={i === 0 ? 'true' : 'false'}
            >
              <span class="block font-heading font-bold text-primary-500 text-xs">{laag.naam}</span>
              <span class="block text-accent-500 text-[10px] uppercase tracking-wider font-heading">{laag.dienst}</span>
            </button>
          ))}
        </div>

        <div class="mt-4 bg-slate-50 rounded-xl p-4 min-h-[64px]">
          <p id="ods-info" class="text-secondary-500 text-sm leading-relaxed"></p>
        </div>
      </div>

      <!-- RIGHT: Verband kiezer -->
      <div class="reveal-right bg-white rounded-2xl shadow-lg border border-secondary-100 p-5 sm:p-7 flex flex-col">
        <p class="font-heading font-bold text-primary-500 text-sm uppercase tracking-wider mb-4">Kies uw straatverband</p>

        <div class="relative rounded-xl overflow-hidden aspect-square bg-secondary-100">
          {verbanden.map((v, i) => (
            <img
              src={v.img}
              alt={`Straatverband ${v.naam}`}
              data-verband-img={v.id}
              class="vb-img absolute inset-0 w-full h-full object-cover transition-opacity duration-300"
              style={i === 0 ? 'opacity:1' : 'opacity:0'}
              loading="lazy"
            />
          ))}
        </div>

        <div class="flex flex-wrap gap-2 mt-5">
          {verbanden.map((v, i) => (
            <button
              type="button"
              class="vb-btn px-4 py-2.5 rounded-full border-2 font-heading font-bold text-xs uppercase tracking-wider transition-all duration-200 cursor-pointer"
              data-verband={v.id}
              data-default={i === 0 ? 'true' : 'false'}
            >
              {v.naam}
            </button>
          ))}
        </div>

        <div class="mt-4 bg-slate-50 rounded-xl p-4 min-h-[64px]">
          <p id="vb-info" class="text-secondary-500 text-sm leading-relaxed"></p>
        </div>
      </div>
    </div>
  </div>
</section>

<script
  define:vars={{
    lagenData: lagen.map((l) => ({ id: l.id, tekst: l.tekst, pos: l.pos })),
    verbandenData: verbanden.map((v) => ({ id: v.id, tekst: v.tekst })),
  }}
>
  // ---- Doorsnede ----
  const zone = document.getElementById('ods-zone');
  const info = document.getElementById('ods-info');

  function selectLayer(id) {
    const laag = lagenData.find((l) => l.id === id);
    if (!laag) return;
    document.querySelectorAll('.ods-legend').forEach((b) => {
      const active = b.getAttribute('data-target') === id;
      b.classList.toggle('border-accent-400', active);
      b.classList.toggle('bg-accent-50', active);
    });
    if (zone) {
      zone.style.opacity = '1';
      zone.style.top = laag.pos.top + '%';
      zone.style.left = laag.pos.left + '%';
      zone.style.width = laag.pos.width + '%';
      zone.style.height = laag.pos.height + '%';
    }
    if (info) info.textContent = laag.tekst;
  }

  document.querySelectorAll('.ods-legend').forEach((b) => {
    b.addEventListener('click', () => selectLayer(b.getAttribute('data-target')));
  });
  const odsDefault = document.querySelector('.ods-legend[data-default="true"]');
  if (odsDefault) selectLayer(odsDefault.getAttribute('data-target'));

  // ---- Verband ----
  const vbInfo = document.getElementById('vb-info');

  function selectVerband(id) {
    const v = verbandenData.find((x) => x.id === id);
    if (!v) return;
    document.querySelectorAll('.vb-btn').forEach((b) => {
      const active = b.getAttribute('data-verband') === id;
      b.classList.toggle('border-accent-400', active);
      b.classList.toggle('text-accent-500', active);
      b.classList.toggle('bg-accent-50', active);
      b.classList.toggle('border-secondary-200', !active);
      b.classList.toggle('text-secondary-500', !active);
    });
    document.querySelectorAll('.vb-img').forEach((img) => {
      img.style.opacity = img.getAttribute('data-verband-img') === id ? '1' : '0';
    });
    if (vbInfo) vbInfo.textContent = v.tekst;
  }

  document.querySelectorAll('.vb-btn').forEach((b) => {
    b.addEventListener('click', () => selectVerband(b.getAttribute('data-verband')));
  });
  const vbDefault = document.querySelector('.vb-btn[data-default="true"]');
  if (vbDefault) selectVerband(vbDefault.getAttribute('data-verband'));
</script>
