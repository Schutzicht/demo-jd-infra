---
import { siteConfig } from '../../data/siteConfig';
---

<section class="py-24 sm:py-32 bg-slate-50 relative overflow-hidden">
  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <!-- Header - two-tone -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-12 reveal">
      <div>
        <h2 class="font-heading font-black text-3xl sm:text-5xl lg:text-6xl text-primary-500 leading-tight">
          Recent <span class="text-accent-400">werk</span>
        </h2>
        <p class="text-secondary-400 text-base sm:text-lg mt-3 max-w-md">
          Bekijk een selectie van onze recent afgeronde projecten.
        </p>
      </div>
      <a href="/projecten/" class="group inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-6 py-3 rounded-full font-heading font-bold text-sm uppercase tracking-wider mt-6 sm:mt-0 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 w-fit">
        Alle projecten
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>

    <!-- Horizontal scroll marquee -->
    <div class="flex gap-5 overflow-x-auto scroll-snap-x pb-4 -mx-5 px-5 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 hide-scrollbar">
      {siteConfig.projecten.map((project, i) => (
        <div
          class="reveal flex-shrink-0 w-[80vw] min-w-[280px] sm:w-[45vw] lg:w-[30vw]"
          style={`transition-delay: ${i * 0.15}s;`}
        >
          <div class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 aspect-video">
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
            />
            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-500"></div>
            <!-- Title overlay at bottom -->
            <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6">
              <span class="text-white/60 text-xs font-heading uppercase tracking-widest block mb-1">
                {new Date(project.date).toLocaleDateString('nl-NL', { year: 'numeric', month: 'long' })}
              </span>
              <h3 class="font-heading font-bold text-lg sm:text-xl text-white leading-tight">
                {project.title}
              </h3>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
