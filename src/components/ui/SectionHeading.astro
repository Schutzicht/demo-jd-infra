---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const { title, subtitle, align = 'center', light = false } = Astro.props;
const alignClass = align === 'center' ? 'text-center' : 'text-left';
const titleColor = light ? 'text-white' : 'text-primary-500';
const subtitleColor = light ? 'text-primary-100' : 'text-secondary-500';
const lineAlign = align === 'center' ? 'mx-auto' : '';
---

<div class={`mb-10 md:mb-14 ${alignClass}`}>
  <div class={`w-10 h-px bg-accent-400 mb-5 ${lineAlign}`}></div>
  <h2 class={`display-lg ${titleColor} mb-4`}>{title}</h2>
  {subtitle && (
    <p class={`text-lg md:text-xl ${subtitleColor} max-w-2xl ${align === 'center' ? 'mx-auto' : ''}`}>{subtitle}</p>
  )}
</div>
