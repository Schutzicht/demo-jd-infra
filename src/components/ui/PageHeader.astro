---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: BreadcrumbItem[];
  backgroundImage: string;
}

const { title, subtitle, breadcrumbs = [], backgroundImage } = Astro.props;
---

<section class="relative -mt-20 sm:-mt-24 pt-32 sm:pt-48 pb-16 sm:pb-20 overflow-hidden min-h-[280px] sm:min-h-[400px] flex items-end">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src={backgroundImage} alt="" class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-t from-primary-900/90 via-primary-900/60 to-primary-900/30"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary-900/50 via-transparent to-transparent"></div>
  </div>

  <!-- Grain -->
  <div class="absolute inset-0 grain z-[1]"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 w-full">
    <!-- Breadcrumbs -->
    {breadcrumbs.length > 0 && (
      <nav class="mb-5" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm font-heading">
          <li>
            <a href="/" class="text-white/50 hover:text-accent-400 transition-colors">Home</a>
          </li>
          {breadcrumbs.map((crumb) => (
            <li class="flex items-center gap-2">
              <svg class="w-3 h-3 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              {crumb.href ? (
                <a href={crumb.href} class="text-white/50 hover:text-accent-400 transition-colors">{crumb.label}</a>
              ) : (
                <span class="text-accent-400 font-semibold">{crumb.label}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    <!-- Title -->
    <h1 class="font-heading font-black text-3xl md:text-5xl lg:text-6xl text-white leading-[0.95] mb-4">
      {title}
    </h1>

    <!-- Accent line -->
    <div class="w-16 h-1 bg-accent-400 mb-4"></div>

    <!-- Subtitle -->
    {subtitle && (
      <p class="text-white/70 text-base sm:text-lg max-w-2xl leading-relaxed">
        {subtitle}
      </p>
    )}
  </div>
</section>
