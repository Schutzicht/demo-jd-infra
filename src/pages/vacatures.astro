---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { siteConfig } from '../data/siteConfig';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Vacatures" description="Bekijk de openstaande vacatures bij JD Infra Aannemingsbedrijf BV in Koudekerke.">
  <PageHeader
    title="Vacatures"
    subtitle="Werken bij JD Infra? Bekijk onze openstaande vacatures."
    breadcrumbs={[{ label: 'Vacatures' }]}
  />

  <!-- Content -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- No vacancies message -->
      <div class="reveal bg-slate-50 border border-secondary-100 p-8 md:p-12 text-center mb-12">
        <div class="w-16 h-16 bg-accent-400/10 flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-500 mb-4">
          Op dit moment hebben wij geen openstaande vacatures
        </h2>
        <p class="text-secondary-500 text-lg leading-relaxed max-w-xl mx-auto">
          Momenteel zijn er geen vacatures beschikbaar. Wij zijn echter altijd op zoek naar gemotiveerde vakmensen. Voel je vrij om een open sollicitatie te sturen!
        </p>
      </div>

      <!-- Open application -->
      <div class="reveal" style="transition-delay: 100ms">
        <div class="w-12 h-1 bg-accent-400 mb-6"></div>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-500 mb-6">Open sollicitatie</h2>
        <p class="text-secondary-600 text-lg leading-relaxed mb-6">
          Ben je een ervaren vakman in de grond-, weg- en waterbouw? Of ben je op zoek naar een leerplek? JD Infra is altijd geinteresseerd in gemotiveerde mensen die ons team willen versterken.
        </p>
        <p class="text-secondary-500 leading-relaxed mb-8">
          Stuur je CV en motivatie naar onderstaand e-mailadres of neem telefonisch contact met ons op. Wij horen graag van je!
        </p>

        <div class="bg-slate-50 border border-secondary-100 p-6 md:p-8">
          <h3 class="font-heading text-lg font-semibold text-primary-500 mb-4">Contactgegevens</h3>
          <ul class="space-y-3">
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${siteConfig.contact.email}`} class="text-accent-500 hover:text-accent-600 font-medium transition-colors">
                {siteConfig.contact.email}
              </a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${siteConfig.contact.phone}`} class="text-accent-500 hover:text-accent-600 font-medium transition-colors">
                {siteConfig.contact.phone}
              </a>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span class="text-secondary-600">
                {siteConfig.contact.address}, {siteConfig.contact.postalCode} {siteConfig.contact.city}
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
