---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout title="Vacatures - Werk bij JD Infra" description="Werken bij JD Infra? Bekijk onze openstaande vacatures en word onderdeel van een vakkundig team in Zeeland.">
  <PageHeader
    title="Werk bij JD Infra"
    subtitle="Word onderdeel van een vakkundig team in de mooiste provincie van Nederland"
    breadcrumbs={[{ label: 'Vacatures' }]}
  />

  <!-- Waarom werken bij JD Infra -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading font-black text-2xl sm:text-3xl lg:text-4xl text-primary-500 mb-3">
          Waarom werken bij <span class="text-accent-400">JD Infra?</span>
        </h2>
        <p class="text-secondary-400 max-w-xl mx-auto">Bij ons draait het om vakmanschap, teamwork en plezier in het werk</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <!-- Benefit 1 -->
        <div class="reveal bg-white rounded-2xl border border-secondary-100 shadow-sm hover:shadow-md transition-shadow p-7">
          <div class="w-12 h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Goed salaris</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Marktconform salaris met ruimte voor groei</p>
        </div>

        <!-- Benefit 2 -->
        <div class="reveal bg-white rounded-2xl border border-secondary-100 shadow-sm hover:shadow-md transition-shadow p-7" style="transition-delay: 80ms">
          <div class="w-12 h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Geen twee dagen hetzelfde</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Afwisselend buitenwerk in heel Zeeland</p>
        </div>

        <!-- Benefit 3 -->
        <div class="reveal bg-white rounded-2xl border border-secondary-100 shadow-sm hover:shadow-md transition-shadow p-7" style="transition-delay: 160ms">
          <div class="w-12 h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Modern materieel</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Werk met de nieuwste machines en gereedschappen</p>
        </div>

        <!-- Benefit 4 -->
        <div class="reveal bg-white rounded-2xl border border-secondary-100 shadow-sm hover:shadow-md transition-shadow p-7" style="transition-delay: 240ms">
          <div class="w-12 h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Hecht team</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Klein familiair bedrijf, 12-15 collega's</p>
        </div>

        <!-- Benefit 5 -->
        <div class="reveal bg-white rounded-2xl border border-secondary-100 shadow-sm hover:shadow-md transition-shadow p-7" style="transition-delay: 320ms">
          <div class="w-12 h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Doorgroeimogelijkheden</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Van stratenmaker tot voorman</p>
        </div>

        <!-- Benefit 6 -->
        <div class="reveal bg-white rounded-2xl border border-secondary-100 shadow-sm hover:shadow-md transition-shadow p-7" style="transition-delay: 400ms">
          <div class="w-12 h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Vaste aanstelling</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Zekerheid en stabiliteit</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Open Vacatures -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading font-black text-2xl sm:text-3xl lg:text-4xl text-primary-500 mb-3">
          Open <span class="text-accent-400">vacatures</span>
        </h2>
        <p class="text-secondary-400 max-w-xl mx-auto">Bekijk onze huidige openstaande functies</p>
      </div>

      <div class="space-y-5">
        <!-- Vacancy 1: Stratenmaker -->
        <div class="reveal vacancy-card bg-white rounded-2xl border border-secondary-100 shadow-sm overflow-hidden">
          <button class="vacancy-trigger w-full p-6 sm:p-8 text-left flex items-center justify-between gap-4 hover:bg-slate-50/50 transition-colors">
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="inline-block px-3 py-1 rounded-full bg-accent-400/10 text-accent-400 font-heading font-semibold text-xs">Fulltime</span>
                <span class="inline-block px-3 py-1 rounded-full bg-primary-500/5 text-primary-500 font-heading font-semibold text-xs">Koudekerke</span>
              </div>
              <h3 class="font-heading font-bold text-xl text-primary-500">Stratenmaker</h3>
              <p class="text-secondary-400 text-sm mt-1">Ervaren stratenmaker gezocht voor diverse projecten</p>
            </div>
            <svg class="vacancy-icon w-6 h-6 text-accent-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="vacancy-content hidden px-6 sm:px-8 pb-6 sm:pb-8">
            <div class="border-t border-secondary-100 pt-6">
              <h4 class="font-heading font-bold text-primary-500 mb-3">Wat ga je doen?</h4>
              <p class="text-secondary-400 text-sm leading-relaxed mb-4">Als stratenmaker bij JD Infra ben je verantwoordelijk voor het leggen van diverse soorten bestrating. Van sierbestrating in particuliere tuinen tot klinkerwerk in woonwijken.</p>

              <h4 class="font-heading font-bold text-primary-500 mb-3">Wat vragen wij?</h4>
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Minimaal 2 jaar ervaring als stratenmaker
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Rijbewijs B
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Je bent een echte teamspeler
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Zelfstandig en nauwkeurig werken
                </li>
              </ul>

              <a href="#solliciteer" class="inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-8 py-3 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
                Solliciteer direct
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Vacancy 2: Machinist -->
        <div class="reveal vacancy-card bg-white rounded-2xl border border-secondary-100 shadow-sm overflow-hidden" style="transition-delay: 100ms">
          <button class="vacancy-trigger w-full p-6 sm:p-8 text-left flex items-center justify-between gap-4 hover:bg-slate-50/50 transition-colors">
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="inline-block px-3 py-1 rounded-full bg-accent-400/10 text-accent-400 font-heading font-semibold text-xs">Fulltime</span>
                <span class="inline-block px-3 py-1 rounded-full bg-primary-500/5 text-primary-500 font-heading font-semibold text-xs">Koudekerke</span>
              </div>
              <h3 class="font-heading font-bold text-xl text-primary-500">Machinist (mini)graafmachine</h3>
              <p class="text-secondary-400 text-sm mt-1">Bedien onze graafmachines op diverse locaties in Zeeland</p>
            </div>
            <svg class="vacancy-icon w-6 h-6 text-accent-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="vacancy-content hidden px-6 sm:px-8 pb-6 sm:pb-8">
            <div class="border-t border-secondary-100 pt-6">
              <h4 class="font-heading font-bold text-primary-500 mb-3">Wat ga je doen?</h4>
              <p class="text-secondary-400 text-sm leading-relaxed mb-4">Als machinist ben je verantwoordelijk voor het bedienen van (mini)graafmachines bij diverse grond- en infraprojecten. Je werkt op wisselende locaties in Zeeland, van particuliere tuinen tot grote bouwprojecten.</p>

              <h4 class="font-heading font-bold text-primary-500 mb-3">Wat vragen wij?</h4>
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Ervaring met het bedienen van (mini)graafmachines
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Rijbewijs B (BE is een pre)
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  VCA certificaat (of bereid dit te halen)
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Bereid om ook hand- en spanwerk te verrichten
                </li>
              </ul>

              <a href="#solliciteer" class="inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-8 py-3 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
                Solliciteer direct
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Vacancy 3: Grondwerker -->
        <div class="reveal vacancy-card bg-white rounded-2xl border border-secondary-100 shadow-sm overflow-hidden" style="transition-delay: 200ms">
          <button class="vacancy-trigger w-full p-6 sm:p-8 text-left flex items-center justify-between gap-4 hover:bg-slate-50/50 transition-colors">
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="inline-block px-3 py-1 rounded-full bg-accent-400/10 text-accent-400 font-heading font-semibold text-xs">Fulltime</span>
                <span class="inline-block px-3 py-1 rounded-full bg-primary-500/5 text-primary-500 font-heading font-semibold text-xs">Koudekerke</span>
              </div>
              <h3 class="font-heading font-bold text-xl text-primary-500">Grondwerker / Allround medewerker</h3>
              <p class="text-secondary-400 text-sm mt-1">Veelzijdige medewerker voor ons grondwerkteam</p>
            </div>
            <svg class="vacancy-icon w-6 h-6 text-accent-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="vacancy-content hidden px-6 sm:px-8 pb-6 sm:pb-8">
            <div class="border-t border-secondary-100 pt-6">
              <h4 class="font-heading font-bold text-primary-500 mb-3">Wat ga je doen?</h4>
              <p class="text-secondary-400 text-sm leading-relaxed mb-4">Als grondwerker ben je betrokken bij uiteenlopende werkzaamheden: van het graven van sleuven voor riolering tot het bouwrijp maken van terreinen. Geen dag is hetzelfde en je leert continu bij.</p>

              <h4 class="font-heading font-bold text-primary-500 mb-3">Wat vragen wij?</h4>
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Ervaring in de GWW is een pre, maar niet vereist
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Rijbewijs B
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Fysiek fit en niet bang om de handen vuil te maken
                </li>
                <li class="flex items-start gap-2 text-secondary-400 text-sm">
                  <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Gemotiveerd en leergierig
                </li>
              </ul>

              <a href="#solliciteer" class="inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-8 py-3 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5">
                Solliciteer direct
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team photo section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="reveal">
          <img
            src="/fotos-jd-infra/fotos jd infra/DJI_0004-1024x576.jpg.jpeg"
            alt="JD Infra werkplaats en team vanuit de lucht"
            class="w-full rounded-2xl shadow-lg object-cover aspect-video"
            loading="lazy"
          />
        </div>
        <div class="reveal" style="transition-delay: 100ms">
          <h2 class="font-heading font-black text-2xl sm:text-3xl text-primary-500 mb-4">
            Ons team en <span class="text-accent-400">werkplaats</span>
          </h2>
          <div class="w-16 h-1 bg-accent-400 mb-6"></div>
          <p class="text-secondary-500 leading-relaxed mb-4">
            Bij JD Infra werken we met een hecht team van circa 12-15 vakmensen. Vanuit onze werkplaats in Koudekerke trekken we er elke dag op uit voor projecten in heel Zeeland.
          </p>
          <p class="text-secondary-400 leading-relaxed mb-6">
            De sfeer is informeel en direct. We werken hard, maar lachen ook veel. Nieuwe collega's worden snel onderdeel van het team. Of je nu een ervaren vakman bent of net begint in de GWW — bij ons krijg je de kans om te groeien.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="px-4 py-2 rounded-full bg-accent-400/10 text-accent-400 font-heading font-semibold text-sm">Familiair</span>
            <span class="px-4 py-2 rounded-full bg-accent-400/10 text-accent-400 font-heading font-semibold text-sm">Vakmanschap</span>
            <span class="px-4 py-2 rounded-full bg-accent-400/10 text-accent-400 font-heading font-semibold text-sm">Zeeland</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Open sollicitatie + formulier -->
  <section class="py-16 md:py-24 bg-slate-50" id="solliciteer">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-heading font-black text-2xl sm:text-3xl lg:text-4xl text-primary-500 mb-3">
          Staat jouw functie er <span class="text-accent-400">niet bij?</span>
        </h2>
        <p class="text-secondary-400 max-w-xl mx-auto leading-relaxed">
          Wij zijn altijd op zoek naar gemotiveerde vakmensen. Stuur je CV en motivatie en wie weet spreken we elkaar binnenkort!
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-secondary-100 shadow-lg p-6 sm:p-8 lg:p-10">
        <form action="#" method="POST" class="space-y-6" enctype="multipart/form-data">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="sol-naam" class="block text-sm font-medium text-secondary-500 mb-1.5">Naam *</label>
              <input type="text" id="sol-naam" name="naam" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="Je volledige naam" />
            </div>
            <div>
              <label for="sol-telefoon" class="block text-sm font-medium text-secondary-500 mb-1.5">Telefoonnummer *</label>
              <input type="tel" id="sol-telefoon" name="telefoon" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="06 - 1234 5678" />
            </div>
          </div>

          <div>
            <label for="sol-email" class="block text-sm font-medium text-secondary-500 mb-1.5">E-mailadres *</label>
            <input type="email" id="sol-email" name="email" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="je@email.nl" />
          </div>

          <div>
            <label for="sol-motivatie" class="block text-sm font-medium text-secondary-500 mb-1.5">Motivatie *</label>
            <textarea id="sol-motivatie" name="motivatie" required rows="4" class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white resize-vertical" placeholder="Vertel kort over jezelf en waarom je bij JD Infra wilt werken..."></textarea>
          </div>

          <div>
            <label for="sol-cv" class="block text-sm font-medium text-secondary-500 mb-1.5">CV uploaden</label>
            <div class="relative">
              <input type="file" id="sol-cv" name="cv" accept=".pdf,.doc,.docx" class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white file:mr-4 file:py-1 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-heading file:font-semibold file:bg-accent-400/10 file:text-accent-400 hover:file:bg-accent-400/20" />
            </div>
            <p class="text-secondary-300 text-xs mt-1">PDF, DOC of DOCX (max 5MB)</p>
          </div>

          <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 bg-accent-400 hover:bg-accent-500 text-white px-10 py-4 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            Sollicitatie versturen
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </button>
        </form>
      </div>

      <!-- Direct contact alternative -->
      <div class="mt-8 text-center">
        <p class="text-secondary-400 text-sm mb-3">Of neem direct contact op:</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={`tel:${siteConfig.contact.phone}`} class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-500 font-heading font-semibold text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            {siteConfig.contact.phone}
          </a>
          <a href={`mailto:${siteConfig.contact.email}`} class="inline-flex items-center gap-2 text-accent-400 hover:text-accent-500 font-heading font-semibold text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            {siteConfig.contact.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Vacancy accordion
  document.querySelectorAll('.vacancy-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const card = trigger.closest('.vacancy-card');
      if (!card) return;

      const content = card.querySelector('.vacancy-content');
      const icon = card.querySelector('.vacancy-icon');
      const isOpen = content && !content.classList.contains('hidden');

      // Close all others
      document.querySelectorAll('.vacancy-card').forEach((otherCard) => {
        const otherContent = otherCard.querySelector('.vacancy-content');
        const otherIcon = otherCard.querySelector('.vacancy-icon');
        if (otherContent) otherContent.classList.add('hidden');
        if (otherIcon) otherIcon.classList.remove('rotate-180');
      });

      // Toggle current
      if (!isOpen && content && icon) {
        content.classList.remove('hidden');
        icon.classList.add('rotate-180');
      }
    });
  });
</script>
