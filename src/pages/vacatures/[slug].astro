---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return siteConfig.vacatures.map((vac) => ({
    params: { slug: vac.slug },
    props: { vac },
  }));
}

const { vac } = Astro.props;
---

<BaseLayout title={`${vac.title} - Vacature`} description={vac.tagline} transparentHeader={true}>
  <!-- Hero -->
  <section class="relative bg-mesh-ink pt-36 pb-16 sm:pt-44 sm:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-grid-fine opacity-40"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/50 text-sm mb-8 font-heading">
        <a href="/vacatures/" class="hover:text-accent-300 transition-colors">Vacatures</a>
        <span>/</span>
        <span class="text-white/80">{vac.title}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-2 mb-5">
        <span class="inline-block px-3 py-1 rounded-full bg-accent-400/20 text-accent-300 font-heading font-bold text-xs">{vac.type}</span>
        <span class="inline-block px-3 py-1 rounded-full bg-white/10 text-white/80 font-heading font-semibold text-xs">{vac.location}</span>
      </div>

      <h1 class="display-lg text-white mb-4">{vac.title}</h1>
      <p class="text-white/70 text-lg max-w-2xl leading-relaxed">{vac.tagline}</p>

      <a href="#solliciteer" class="inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-8 py-4 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-lg hover:-translate-y-0.5 mt-8">
        Solliciteer direct
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  <!-- Body -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-14">
        <!-- Main -->
        <div class="lg:col-span-2 space-y-10">
          <div class="reveal">
            <h2 class="display-md text-primary-500 mb-4">Over de functie</h2>
            <p class="text-secondary-500 leading-relaxed">{vac.intro}</p>
          </div>

          <div class="reveal">
            <h2 class="display-md text-primary-500 mb-5">Wat ga je doen?</h2>
            <ul class="space-y-3">
              {vac.taken.map((t) => (
                <li class="flex items-start gap-3 text-secondary-500">
                  <span class="mt-1 w-5 h-5 rounded-full bg-accent-400/10 flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-accent-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  {t}
                </li>
              ))}
            </ul>
          </div>

          <div class="reveal">
            <h2 class="display-md text-primary-500 mb-5">Wat vragen wij?</h2>
            <ul class="space-y-3">
              {vac.eisen.map((e) => (
                <li class="flex items-start gap-3 text-secondary-500">
                  <span class="mt-1 w-5 h-5 rounded-full bg-accent-400/10 flex items-center justify-center shrink-0">
                    <svg class="w-3 h-3 text-accent-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  {e}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Sticky side: wat bieden wij -->
        <aside class="lg:col-span-1">
          <div class="lg:sticky lg:top-28 bg-slate-50 rounded-2xl border border-secondary-100 p-6 sm:p-7">
            <h3 class="font-heading font-bold text-primary-500 text-lg mb-5">Wat bieden wij?</h3>
            <ul class="space-y-3 mb-6">
              {vac.bieden.map((b) => (
                <li class="flex items-start gap-3 text-secondary-500 text-sm">
                  <span class="mt-1 w-4 h-4 rounded-full bg-accent-400 flex items-center justify-center shrink-0">
                    <svg class="w-2.5 h-2.5 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  {b}
                </li>
              ))}
            </ul>
            <a href="#solliciteer" class="w-full inline-flex items-center justify-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-6 py-3.5 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300">
              Solliciteer
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <p class="text-secondary-400 text-xs text-center mt-4">
              Vragen? Bel <a href={`tel:${siteConfig.contact.phone}`} class="text-accent-500 font-semibold">{siteConfig.contact.phone}</a>
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Solliciteer -->
  <section class="py-16 md:py-24 bg-slate-50" id="solliciteer">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <span class="eyebrow eyebrow-center mb-4">Solliciteren</span>
        <h2 class="display-md text-primary-500">Solliciteer op {vac.title}</h2>
      </div>

      <div class="bg-white rounded-2xl border border-secondary-100 shadow-lg p-6 sm:p-8 lg:p-10">
        <form id="sollicitatie-form" action="#" method="POST" class="space-y-6" enctype="multipart/form-data">
          <input type="hidden" name="functie" value={vac.title} />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="sol-naam" class="block text-sm font-medium text-secondary-500 mb-1.5">Naam *</label>
              <input type="text" id="sol-naam" name="naam" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="Je volledige naam" />
            </div>
            <div>
              <label for="sol-telefoon" class="block text-sm font-medium text-secondary-500 mb-1.5">Telefoonnummer *</label>
              <input type="tel" id="sol-telefoon" name="telefoon" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="06 - 1234 5678" />
            </div>
          </div>
          <div>
            <label for="sol-email" class="block text-sm font-medium text-secondary-500 mb-1.5">E-mailadres *</label>
            <input type="email" id="sol-email" name="email" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="je@email.nl" />
          </div>
          <div>
            <label for="sol-motivatie" class="block text-sm font-medium text-secondary-500 mb-1.5">Motivatie *</label>
            <textarea id="sol-motivatie" name="motivatie" required rows="4" class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white resize-vertical" placeholder="Vertel kort over jezelf en waarom je bij JD Infra wilt werken..."></textarea>
          </div>
          <div>
            <label for="sol-cv" class="block text-sm font-medium text-secondary-500 mb-1.5">CV uploaden</label>
            <input type="file" id="sol-cv" name="cv" accept=".pdf,.doc,.docx" class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white file:mr-4 file:py-1 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-heading file:font-semibold file:bg-accent-400/10 file:text-accent-400 hover:file:bg-accent-400/20" />
            <p class="text-secondary-300 text-xs mt-1">PDF, DOC of DOCX (max 5MB)</p>
          </div>
          <button type="submit" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 bg-accent-400 hover:bg-accent-500 text-white px-10 py-4 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            Sollicitatie versturen
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </button>
        </form>
      </div>

      <div class="mt-8 text-center">
        <p class="text-secondary-400 text-sm mb-3">Of bel geheel vrijblijvend:</p>
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2">
          <a href="tel:0118563535" class="inline-flex items-center gap-2 text-accent-500 hover:text-accent-600 font-heading font-semibold text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            0118 563535
          </a>
          <a href="tel:0646424103" class="inline-flex items-center gap-2 text-accent-500 hover:text-accent-600 font-heading font-semibold text-sm transition-colors">
            0646 42 41 03 <span class="text-secondary-400 font-normal">(Luuk Roelse)</span>
          </a>
          <a href="tel:0610903793" class="inline-flex items-center gap-2 text-accent-500 hover:text-accent-600 font-heading font-semibold text-sm transition-colors">
            0610 90 37 93 <span class="text-secondary-400 font-normal">(Jaap Sturm)</span>
          </a>
          <a href={`mailto:${siteConfig.contact.email}`} class="inline-flex items-center gap-2 text-accent-500 hover:text-accent-600 font-heading font-semibold text-sm transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            {siteConfig.contact.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('sollicitatie-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }
    const naam = (document.getElementById('sol-naam') as HTMLInputElement)?.value || '';
    form.innerHTML = `
      <div class="text-center py-10">
        <div class="w-16 h-16 rounded-full bg-accent-400/10 flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
        </div>
        <h3 class="font-heading font-bold text-2xl text-primary-500 mb-2">Bedankt${naam ? ', ' + naam : ''}!</h3>
        <p class="text-secondary-400 max-w-sm mx-auto">We hebben je sollicitatie ontvangen en nemen zo snel mogelijk contact met je op.</p>
      </div>`;
    form.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>
