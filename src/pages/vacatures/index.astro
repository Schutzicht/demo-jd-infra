---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import { siteConfig } from '../../data/siteConfig';

// Cohesive line-icon set (1.75 stroke, rounded)
const voordelen = [
  { titel: 'Marktconform salaris', tekst: 'Een eerlijk salaris met ruimte om door te groeien.', icon: 'euro' },
  { titel: 'Geen dag hetzelfde', tekst: 'Afwisselend buitenwerk op wisselende locaties in Zeeland.', icon: 'route' },
  { titel: 'Modern materieel', tekst: 'Werken met een goed onderhouden, modern machinepark.', icon: 'machine' },
  { titel: 'Hecht team', tekst: 'Klein, familiair bedrijf met 12-15 vaste collega’s.', icon: 'team' },
  { titel: 'Doorgroeien', tekst: 'Van stratenmaker of grondwerker tot uitvoerder.', icon: 'growth' },
  { titel: 'Dicht bij huis', tekst: 'Vanuit Koudekerke werk je in de eigen regio.', icon: 'pin' },
];

const icons: Record<string, string> = {
  euro: 'M13 7c-2.5 0-4.5 2.2-4.5 5s2 5 4.5 5c1.3 0 2.5-.6 3.3-1.5M6 10.5h5M6 13.5h5',
  route: 'M6 19a2 2 0 100-4 2 2 0 000 4zM18 9a2 2 0 100-4 2 2 0 000 4zM8 17h6a3 3 0 003-3V9M8 7H7a3 3 0 000 6h1',
  machine: 'M3 17h11v-4l3-1 4 2v3M3 17v-5h8v5M3 17a2 2 0 104 0M15 17a2 2 0 104 0M6 12V8h4v4',
  team: 'M17 20v-2a4 4 0 00-4-4H7a4 4 0 00-4 4v2M10 10a3 3 0 100-6 3 3 0 000 6zM21 20v-2a4 4 0 00-3-3.9M16 4.1a4 4 0 010 7.8',
  growth: 'M4 18l5-5 3 3 7-7M15 9h5v5',
  pin: 'M12 21s-6-5.3-6-10a6 6 0 1112 0c0 4.7-6 10-6 10zM12 11a2 2 0 100-4 2 2 0 000 4z',
};
---

<BaseLayout title="Vacatures - Werk bij JD Infra" description="Werken bij JD Infra? Bekijk onze openstaande vacatures en word onderdeel van een vakkundig team in Zeeland." transparentHeader={true}>
  <PageHeader
    title="Werk bij JD Infra"
    subtitle="Word onderdeel van een vakkundig team in de mooiste provincie van Nederland"
    breadcrumbs={[{ label: 'Vacatures' }]}
    backgroundImage="/projecten/reconstructie-woonstraat/cover.jpg"
  />

  <!-- Waarom werken bij JD Infra -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <span class="eyebrow mb-4">Waarom JD Infra</span>
        <h2 class="display-lg text-primary-500">Vakmanschap, teamwork en <span class="accent-serif">plezier</span>.</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {voordelen.map((v, i) => (
          <div class="reveal group relative bg-white rounded-2xl border border-secondary-100 p-6 sm:p-7 transition-all duration-300 hover:border-accent-400/40 hover:shadow-xl hover:-translate-y-1" style={`transition-delay: ${i * 60}ms`}>
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-accent-400 to-accent-600 flex items-center justify-center mb-5 shadow-lg shadow-accent-400/20">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d={icons[v.icon]} /></svg>
            </div>
            <h3 class="font-heading font-bold text-lg text-primary-500 mb-1.5">{v.titel}</h3>
            <p class="text-secondary-400 text-sm leading-relaxed">{v.tekst}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Openstaande vacatures -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <span class="eyebrow mb-4">Openstaande vacatures</span>
        <h2 class="display-lg text-primary-500">Kom ons <span class="accent-serif">team</span> versterken.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
        {siteConfig.vacatures.map((vac, i) => (
          <a href={`/vacatures/${vac.slug}/`} class="reveal group flex flex-col bg-white rounded-2xl border border-secondary-100 p-7 transition-all duration-300 hover:border-accent-400/40 hover:shadow-xl hover:-translate-y-1" style={`transition-delay: ${i * 80}ms`}>
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="inline-block px-3 py-1 rounded-full bg-accent-400/10 text-accent-500 font-heading font-bold text-xs">{vac.type}</span>
              <span class="inline-block px-3 py-1 rounded-full bg-primary-500/5 text-primary-500 font-heading font-semibold text-xs">{vac.location}</span>
            </div>
            <h3 class="font-heading font-bold text-xl text-primary-500 mb-2 leading-tight">{vac.title}</h3>
            <p class="text-secondary-400 text-sm leading-relaxed mb-6 flex-1">{vac.tagline}</p>
            <span class="editorial-link text-primary-500 group-hover:text-accent-500 border-primary-500/30 group-hover:border-accent-500 w-fit">
              Bekijk vacature
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Open sollicitatie -->
      <div class="mt-10 bg-mesh-ink rounded-2xl p-8 sm:p-10 relative overflow-hidden">
        <div class="absolute inset-0 bg-grid-fine opacity-40"></div>
        <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <div>
            <h3 class="display-md text-white mb-2">Staat jouw functie er niet bij?</h3>
            <p class="text-white/70 max-w-lg">Wij zijn altijd op zoek naar gemotiveerde vakmensen. Stuur een open sollicitatie, wie weet spreken we elkaar snel.</p>
          </div>
          <a href={`mailto:${siteConfig.contact.email}`} class="shrink-0 inline-flex items-center gap-2 bg-accent-400 hover:bg-accent-500 text-white px-7 py-3.5 rounded-full font-heading font-bold text-sm uppercase tracking-wider transition-all duration-300 hover:-translate-y-0.5 w-fit">
            Open sollicitatie
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
