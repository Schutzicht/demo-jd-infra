---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout title="Grondwerk" description="Professioneel grondwerk door JD Infra. Beschoeiingen, bermen, grondwal en wegfundering in heel Zeeland.">
  <PageHeader
    title="Grondwerk"
    subtitle="Grondwerkzaamheden voor beschoeiingen, bermen, grondwal en wegfundering."
    breadcrumbs={[{ label: 'Diensten', href: '/diensten/' }, { label: 'Grondwerk' }]}
    image="/fotos-jd-infra/fotos jd infra/fotos-rittenburg-381z-576x500.jpg.jpeg"
  />

  <!-- Content -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="reveal">
          <img
            src="/fotos-jd-infra/fotos jd infra/fotos-rittenburg-381z-576x500.jpg.jpeg"
            alt="Grondwerk door JD Infra"
            class="w-full h-80 md:h-96 object-cover shadow-xl"
            loading="lazy"
          />
        </div>
        <div class="reveal" style="transition-delay: 100ms">
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-500 mb-6">Grondwerk voor elk project</h2>
          <p class="text-secondary-600 text-lg leading-relaxed mb-6">
            Grondwerk wordt door JD Infra uitgevoerd ten behoeve van beschoeiingen, bermen, grondwal en wegfundering. Met ons eigen machinepark en ervaren machinisten leveren wij kwalitatief grondwerk.
          </p>
          <p class="text-secondary-500 leading-relaxed mb-6">
            Van het bouwrijp maken van terreinen tot het aanbrengen van funderingslagen voor wegen en paden. JD Infra beschikt over het juiste materieel en de expertise voor efficiente uitvoering van grondwerkzaamheden.
          </p>

          <h3 class="font-heading text-lg font-semibold text-primary-500 mb-3">Onze grondwerk diensten:</h3>
          <ul class="space-y-2 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-secondary-600">Beschoeiingen en damwanden</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-secondary-600">Bermen en grondwallen</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-secondary-600">Wegfundering en terreinverharding</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span class="text-secondary-600">Bouwrijp en woonrijp maken</span>
            </li>
          </ul>

          <Button href="/contact/" variant="primary" size="lg">Vraag een offerte aan</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Extra photo -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center reveal">
        <div>
          <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-500 mb-4">Eigen machinepark</h2>
          <p class="text-secondary-600 text-lg leading-relaxed">
            JD Infra beschikt over een uitgebreid machinepark met onder andere wielladers, graafmachines en vrachtwagens. Hierdoor kunnen wij snel en efficient werken op elke locatie in Zeeland.
          </p>
        </div>
        <div>
          <img
            src="/fotos-jd-infra/fotos jd infra/DSCF7911-1920x1080.jpg.jpeg"
            alt="Wiellader van JD Infra aan het werk"
            class="w-full h-64 object-cover shadow-lg"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
