---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { siteConfig } from '../../data/siteConfig';
---

<BaseLayout title="Diensten" description="JD Infra biedt professioneel straatwerk, riolering en grondwerk door heel Zeeland.">
  <PageHeader
    title="Onze diensten"
    subtitle="JD Infra biedt een compleet pakket aan infrastructurele diensten met ervaren vakmensen."
    breadcrumbs={[{ label: 'Diensten' }]}
  />

  <!-- Services Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {siteConfig.diensten.map((dienst, i) => (
          <a
            href={`/diensten/${dienst.slug}/`}
            class="group reveal bg-white overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-secondary-100 hover:-translate-y-1"
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={dienst.image}
                alt={dienst.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <div class="p-6 border-l-4 border-transparent group-hover:border-accent-400 transition-all duration-300">
              <h2 class="font-heading text-2xl font-bold text-primary-500 uppercase tracking-wider mb-3">
                {dienst.title}
              </h2>
              <p class="text-secondary-500 leading-relaxed mb-4">{dienst.description}</p>
              <span class="inline-flex items-center gap-2 text-accent-400 font-heading font-semibold text-sm uppercase tracking-wider group-hover:gap-3 transition-all">
                Meer informatie
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Extra info -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-primary-500 mb-6">Waarom JD Infra?</h2>
      <p class="text-secondary-600 text-lg leading-relaxed mb-4">
        Met meer dan 18 jaar ervaring in de infrastructurele sector zijn wij uw betrouwbare partner voor projecten in heel Zeeland. Ons team van ervaren vakmensen staat garant voor kwaliteit en vakmanschap.
      </p>
      <p class="text-secondary-500 leading-relaxed">
        Wij werken voor particulieren, bedrijven en overheidsinstellingen en realiseren zowel kleine als grote projecten.
      </p>
    </div>
  </section>
</BaseLayout>
