---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Pagina niet gevonden" description="De pagina die u zoekt bestaat niet of is verplaatst.">
  <section class="bg-primary-500 min-h-[70vh] flex items-center justify-center pt-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-heading text-8xl md:text-9xl font-bold text-accent-400 mb-4">404</p>
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
        Pagina niet gevonden
      </h1>
      <p class="text-primary-200 text-lg mb-8 leading-relaxed">
        De pagina die u zoekt bestaat niet of is verplaatst. Gebruik de navigatie om terug te keren naar een bestaande pagina.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" variant="primary" size="lg">Naar de homepage</Button>
        <Button href="/contact/" variant="outline" size="lg" class="!border-white !text-white hover:!bg-white hover:!text-primary-500">Contact opnemen</Button>
      </div>
    </div>
  </section>
</BaseLayout>
