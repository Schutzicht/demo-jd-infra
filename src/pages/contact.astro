<script>
  // Chip button selection logic
  function setupChipGroup(containerId: string, hiddenInputId: string, allowMultiple = false) {
    const container = document.getElementById(containerId);
    const hiddenInput = document.getElementById(hiddenInputId) as HTMLInputElement;
    if (!container || !hiddenInput) return;

    container.querySelectorAll('.chip-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!allowMultiple) {
          container.querySelectorAll('.chip-btn').forEach((b) => {
            b.classList.remove('border-accent-400', 'bg-accent-400', 'text-white');
            b.classList.add('border-secondary-200', 'text-secondary-500');
          });
        }

        const isActive = btn.classList.contains('bg-accent-400');
        if (isActive) {
          btn.classList.remove('border-accent-400', 'bg-accent-400', 'text-white');
          btn.classList.add('border-secondary-200', 'text-secondary-500');
          hiddenInput.value = '';
        } else {
          btn.classList.remove('border-secondary-200', 'text-secondary-500');
          btn.classList.add('border-accent-400', 'bg-accent-400', 'text-white');
          hiddenInput.value = (btn as HTMLElement).dataset.value || '';
        }
      });
    });
  }

  setupChipGroup('project-type-chips', 'type_project');
  setupChipGroup('budget-chips', 'budget');

  // Project card click -> auto-fill form
  document.querySelectorAll('.project-card').forEach((card) => {
    card.addEventListener('click', () => {
      const projectType = (card as HTMLElement).dataset.project || '';
      const description = (card as HTMLElement).dataset.description || '';

      // Set project type chip
      const chipContainer = document.getElementById('project-type-chips');
      const hiddenInput = document.getElementById('type_project') as HTMLInputElement;
      if (chipContainer && hiddenInput) {
        chipContainer.querySelectorAll('.chip-btn').forEach((btn) => {
          btn.classList.remove('border-accent-400', 'bg-accent-400', 'text-white');
          btn.classList.add('border-secondary-200', 'text-secondary-500');
          if ((btn as HTMLElement).dataset.value === projectType) {
            btn.classList.remove('border-secondary-200', 'text-secondary-500');
            btn.classList.add('border-accent-400', 'bg-accent-400', 'text-white');
          }
        });
        hiddenInput.value = projectType;
      }

      // Set description
      const omschrijving = document.getElementById('omschrijving') as HTMLTextAreaElement;
      if (omschrijving) {
        omschrijving.value = description;
      }

      // Scroll to form
      const formSection = document.getElementById('offerte-formulier');
      if (formSection) {
        formSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item');
      if (!item) return;

      const content = item.querySelector('.faq-content');
      const icon = item.querySelector('.faq-icon');
      const isOpen = content && !content.classList.contains('hidden');

      // Close all others
      document.querySelectorAll('.faq-item').forEach((otherItem) => {
        const otherContent = otherItem.querySelector('.faq-content');
        const otherIcon = otherItem.querySelector('.faq-icon');
        if (otherContent) otherContent.classList.add('hidden');
        if (otherIcon) otherIcon.classList.remove('rotate-180');
      });

      // Toggle current
      if (!isOpen && content && icon) {
        content.classList.remove('hidden');
        icon.classList.add('rotate-180');
      }
    });
  });
</script>
