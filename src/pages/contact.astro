---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout title="Offerte aanvragen" description="Vraag vrijblijvend een offerte aan bij JD Infra. Wij reageren binnen 2 werkdagen met een passend voorstel." transparentHeader={true}>
  <PageHeader
    title="Offerte aanvragen"
    subtitle="Vraag vrijblijvend een offerte aan voor uw project. Wij reageren binnen 2 werkdagen."
    breadcrumbs={[{ label: 'Offerte aanvragen' }]}
    backgroundImage="/fotos-jd-infra/fotos jd infra/IMG_4120c-1024x683.jpg.jpeg"
  />

  <!-- USP Cards -->
  <section class="py-14 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <!-- USP 1: Gratis thuisadvies -->
        <div class="reveal bg-white rounded-2xl shadow-md p-8 text-center hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-accent-400/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Gratis thuisadvies</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Wij komen bij u langs voor een vrijblijvende inspectie en advies</p>
        </div>

        <!-- USP 2: Binnen 2 werkdagen reactie -->
        <div class="reveal bg-white rounded-2xl shadow-md p-8 text-center hover:shadow-lg transition-shadow" style="transition-delay: 100ms">
          <div class="w-14 h-14 bg-accent-400/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Binnen 2 werkdagen reactie</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">Snel en persoonlijk contact, geen weken wachten</p>
        </div>

        <!-- USP 3: Vaste prijs -->
        <div class="reveal bg-white rounded-2xl shadow-md p-8 text-center hover:shadow-lg transition-shadow" style="transition-delay: 200ms">
          <div class="w-14 h-14 bg-accent-400/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-500 mb-2">Vaste prijs, geen verrassingen</h3>
          <p class="text-secondary-400 text-sm leading-relaxed">U weet vooraf precies waar u aan toe bent</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Veelgevraagd door particulieren -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-heading font-black text-2xl sm:text-3xl text-primary-500 mb-3">
          Veelgevraagd door <span class="text-accent-400">particulieren</span>
        </h2>
        <p class="text-secondary-400 max-w-xl mx-auto">Klik op een projecttype om het formulier automatisch in te vullen</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-5" id="project-cards">
        <button class="project-card reveal group bg-white rounded-2xl border-2 border-secondary-100 p-4 sm:p-6 text-left hover:border-accent-400 hover:shadow-lg transition-all cursor-pointer" data-project="straatwerk" data-description="Oprit bestraten met sierbestrating of gebakken klinkers">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-accent-400/20 transition-colors">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
          </div>
          <h3 class="font-heading font-bold text-sm sm:text-base text-primary-500 mb-1">Oprit bestraten</h3>
          <p class="text-secondary-400 text-xs sm:text-sm">Van sierbestrating tot gebakken klinkers</p>
        </button>

        <button class="project-card reveal group bg-white rounded-2xl border-2 border-secondary-100 p-4 sm:p-6 text-left hover:border-accent-400 hover:shadow-lg transition-all cursor-pointer" data-project="grondwerk" data-description="Tuin aanleggen: terras, paden, borders en afwatering" style="transition-delay: 80ms">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-accent-400/20 transition-colors">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-sm sm:text-base text-primary-500 mb-1">Tuin aanleggen</h3>
          <p class="text-secondary-400 text-xs sm:text-sm">Terras, paden, borders en afwatering</p>
        </button>

        <button class="project-card reveal group bg-white rounded-2xl border-2 border-secondary-100 p-4 sm:p-6 text-left hover:border-accent-400 hover:shadow-lg transition-all cursor-pointer" data-project="riolering" data-description="Drainage en riolering: wateroverlast oplossen, nieuwe huisaansluiting" style="transition-delay: 160ms">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-accent-400/20 transition-colors">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-sm sm:text-base text-primary-500 mb-1">Drainage & riolering</h3>
          <p class="text-secondary-400 text-xs sm:text-sm">Wateroverlast oplossen, nieuwe huisaansluiting</p>
        </button>

        <button class="project-card reveal group bg-white rounded-2xl border-2 border-secondary-100 p-4 sm:p-6 text-left hover:border-accent-400 hover:shadow-lg transition-all cursor-pointer" data-project="grondwerk" data-description="Grondwerk voor aanbouw: ontgraven, fundering, bouwrijp maken" style="transition-delay: 240ms">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-accent-400/10 rounded-xl flex items-center justify-center mb-3 sm:mb-4 group-hover:bg-accent-400/20 transition-colors">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          </div>
          <h3 class="font-heading font-bold text-sm sm:text-base text-primary-500 mb-1">Grondwerk voor aanbouw</h3>
          <p class="text-secondary-400 text-xs sm:text-sm">Ontgraven, fundering, bouwrijp maken</p>
        </button>
      </div>
    </div>
  </section>

  <!-- Main content: split layout -->
  <section class="py-16 md:py-24 bg-slate-50" id="offerte-formulier">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- LEFT SIDE: Process steps + FAQ -->
        <div class="lg:col-span-2 order-2 lg:order-1">
          <!-- Hoe werkt het? - Vertical timeline -->
          <div class="mb-12">
            <h2 class="font-heading font-black text-2xl sm:text-3xl text-primary-500 mb-8">
              Hoe werkt <span class="text-accent-400">het?</span>
            </h2>

            <div class="space-y-0">
              <!-- Step 1 -->
              <div class="flex gap-4">
                <div class="flex flex-col items-center">
                  <div class="w-10 h-10 rounded-full bg-accent-400 text-white font-heading font-bold text-sm flex items-center justify-center shrink-0">1</div>
                  <div class="w-0.5 h-full bg-accent-400/20 my-2"></div>
                </div>
                <div class="pb-8">
                  <h3 class="font-heading font-bold text-lg text-primary-500 mb-1">Aanvraag</h3>
                  <p class="text-secondary-400 text-sm leading-relaxed">Vul het formulier in met uw projectgegevens. U ontvangt direct een bevestiging per e-mail.</p>
                </div>
              </div>

              <!-- Step 2 -->
              <div class="flex gap-4">
                <div class="flex flex-col items-center">
                  <div class="w-10 h-10 rounded-full bg-accent-400 text-white font-heading font-bold text-sm flex items-center justify-center shrink-0">2</div>
                  <div class="w-0.5 h-full bg-accent-400/20 my-2"></div>
                </div>
                <div class="pb-8">
                  <h3 class="font-heading font-bold text-lg text-primary-500 mb-1">Inventarisatie</h3>
                  <p class="text-secondary-400 text-sm leading-relaxed">Wij nemen contact op om uw wensen te bespreken en de situatie in kaart te brengen.</p>
                </div>
              </div>

              <!-- Step 3 -->
              <div class="flex gap-4">
                <div class="flex flex-col items-center">
                  <div class="w-10 h-10 rounded-full bg-accent-400 text-white font-heading font-bold text-sm flex items-center justify-center shrink-0">3</div>
                  <div class="w-0.5 h-full bg-accent-400/20 my-2"></div>
                </div>
                <div class="pb-8">
                  <h3 class="font-heading font-bold text-lg text-primary-500 mb-1">Offerte</h3>
                  <p class="text-secondary-400 text-sm leading-relaxed">U ontvangt een gedetailleerde offerte op maat, volledig transparant en zonder verborgen kosten.</p>
                </div>
              </div>

              <!-- Step 4 -->
              <div class="flex gap-4">
                <div class="flex flex-col items-center">
                  <div class="w-10 h-10 rounded-full bg-accent-400 text-white font-heading font-bold text-sm flex items-center justify-center shrink-0">4</div>
                </div>
                <div>
                  <h3 class="font-heading font-bold text-lg text-primary-500 mb-1">Realisatie</h3>
                  <p class="text-secondary-400 text-sm leading-relaxed">Na akkoord plannen wij het project in en gaan onze vakmensen aan de slag.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- FAQ Section -->
          <div>
            <h2 class="font-heading font-black text-2xl sm:text-3xl text-primary-500 mb-6">
              Veelgestelde <span class="text-accent-400">vragen</span>
            </h2>

            <div class="space-y-3" id="faq-section">
              <div class="faq-item border border-secondary-100 rounded-xl overflow-hidden bg-white">
                <button class="faq-trigger w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors">
                  <span class="font-heading font-semibold text-primary-500 text-sm sm:text-base pr-4">Hoe snel kan het project starten?</span>
                  <svg class="faq-icon w-5 h-5 text-accent-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <div class="faq-content hidden px-5 pb-5">
                  <p class="text-secondary-400 text-sm leading-relaxed">Dat hangt af van de omvang en onze planning. Kleine projecten kunnen vaak binnen 2-4 weken starten. Voor grotere projecten plannen we graag een kennismakingsgesprek in.</p>
                </div>
              </div>

              <div class="faq-item border border-secondary-100 rounded-xl overflow-hidden bg-white">
                <button class="faq-trigger w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors">
                  <span class="font-heading font-semibold text-primary-500 text-sm sm:text-base pr-4">Werken jullie ook voor particulieren?</span>
                  <svg class="faq-icon w-5 h-5 text-accent-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <div class="faq-content hidden px-5 pb-5">
                  <p class="text-secondary-400 text-sm leading-relaxed">Zeker! Wij werken voor particulieren, bedrijven en overheidsinstellingen. Van een oprit tot complete woonwijken.</p>
                </div>
              </div>

              <div class="faq-item border border-secondary-100 rounded-xl overflow-hidden bg-white">
                <button class="faq-trigger w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors">
                  <span class="font-heading font-semibold text-primary-500 text-sm sm:text-base pr-4">Wat kost een offerte?</span>
                  <svg class="faq-icon w-5 h-5 text-accent-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <div class="faq-content hidden px-5 pb-5">
                  <p class="text-secondary-400 text-sm leading-relaxed">Niets! Onze offertes zijn geheel gratis en vrijblijvend. Wij komen graag langs om de situatie te bekijken en een passend voorstel te maken.</p>
                </div>
              </div>

              <div class="faq-item border border-secondary-100 rounded-xl overflow-hidden bg-white">
                <button class="faq-trigger w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors">
                  <span class="font-heading font-semibold text-primary-500 text-sm sm:text-base pr-4">In welk gebied zijn jullie actief?</span>
                  <svg class="faq-icon w-5 h-5 text-accent-400 shrink-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </button>
                <div class="faq-content hidden px-5 pb-5">
                  <p class="text-secondary-400 text-sm leading-relaxed">Wij zijn actief in heel Zeeland. Vanuit ons bedrijfspand in Koudekerke bedienen wij de gehele provincie.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Direct contact -->
          <div class="mt-10 bg-white rounded-2xl p-6 sm:p-8 border border-secondary-100 shadow-sm">
            <h3 class="font-heading font-bold text-lg text-primary-500 mb-4">Liever direct contact?</h3>
            <div class="space-y-3">
              <a href={`tel:${siteConfig.contact.phone}`} class="flex items-center gap-3 text-secondary-500 hover:text-accent-400 transition-colors">
                <div class="w-9 h-9 rounded-full bg-accent-400/10 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                </div>
                <span class="font-heading font-semibold">{siteConfig.contact.phone}</span>
              </a>
              <a href={`mailto:${siteConfig.contact.email}`} class="flex items-center gap-3 text-secondary-500 hover:text-accent-400 transition-colors">
                <div class="w-9 h-9 rounded-full bg-accent-400/10 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <span class="font-heading font-semibold">{siteConfig.contact.email}</span>
              </a>
            </div>
          </div>
        </div>

        <!-- RIGHT SIDE: Form -->
        <div class="lg:col-span-3 order-1 lg:order-2">
          <div class="bg-white rounded-2xl border border-secondary-100 shadow-lg p-6 sm:p-8 lg:p-10">
            <h2 class="font-heading font-black text-2xl sm:text-3xl text-primary-500 mb-2">
              Uw <span class="text-accent-400">aanvraag</span>
            </h2>
            <p class="text-secondary-400 text-sm mb-8">Vul onderstaand formulier in en wij nemen binnen 2 werkdagen contact met u op.</p>

            <form action="#" method="POST" class="space-y-6">
              <!-- Personal details -->
              <div>
                <h3 class="font-heading font-bold text-base text-primary-500 mb-4">Uw gegevens</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="voornaam" class="block text-sm font-medium text-secondary-500 mb-1.5">Voornaam *</label>
                    <input type="text" id="voornaam" name="voornaam" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="Uw voornaam" />
                  </div>
                  <div>
                    <label for="achternaam" class="block text-sm font-medium text-secondary-500 mb-1.5">Achternaam *</label>
                    <input type="text" id="achternaam" name="achternaam" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="Uw achternaam" />
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="email" class="block text-sm font-medium text-secondary-500 mb-1.5">E-mailadres *</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="uw@email.nl" />
                </div>
                <div>
                  <label for="telefoon" class="block text-sm font-medium text-secondary-500 mb-1.5">Telefoonnummer *</label>
                  <input type="tel" id="telefoon" name="telefoon" required class="w-full px-4 py-3 border border-secondary-200 rounded-xl focus:border-accent-400 focus:ring-2 focus:ring-accent-400/20 outline-none transition-all text-secondary-700 bg-white" placeholder="06 - 1234 5678" />
                </div>
              </div>

              <!-- Project type - chip buttons -->
              <div>
                <h3 class="font-heading font-bold text-base text-primary-500 mb-4">Projectgegevens</h3>
                <label class="block text-sm font-medium text-secondary-500 mb-2">Type project *</label>
                <div class="flex flex-wrap gap-2" id="project-type-chips">
                  <button type="button" class="chip-btn px-4 py-2 sm:px-5 sm:py-2.5 rounded-full border-2 border-secondary-200 text-secondary-500 font-heading font-semibold text-xs sm:text-sm transition-all duration-300 hover:border-accent-400 hover:text-accent-400" data-value="straatwerk">Straatwerk</button>
                  <button type="button" class="chip-btn px-4 py-2 sm:px-5 sm:py-2.5 rounded-full border-2 border-secondary-200 text-secondary-500 font-heading font-semibold text-xs sm:text-sm transition-all duration-300 hover:border-accent-400 hover:text-accent-400" data-value="riolering">Riolering</button>
                  <button type="button" class="chip-btn px-4 py-2 sm:px-5 sm:py-2.5 rounded-full border-2 border-secondary-200 text-secondary-500 font-heading font-semibold text-xs sm:text-sm transition-all duration-300 hover:border-accent-400 hover:text-accent-400" data-value="grondwerk">Grondwerk</button>
                  <button type="button" class="chip-btn px-4 py-2 sm:px-5 sm:py-2.5 rounded-full border-2 border-secondary-200 text-secondary-500 font-heading font-semibold text-xs sm:text-sm transition-all duration-300 hover:border-accent-400 hover:text-accent-400" data-value="combinatie">Combinatie</button>
                </div>
                <input type="hidden" name="type_project" id="type_project" required />
              </div>

              <!-- Budget indicator chips -->
              <div>
                <label class="block text-sm font-medium text-secondary-500 mb-2">Indicatie budget</label>
                <div class="flex flex-wrap gap-2" id="budget-chips">
                  <button type="button" class="chip-btn px-4 py-2 rounded-full border-2 border-secondary-200 text-secondary-500 font-heading font-semibold text-xs transition-all duration-300 hover:border-accent-400 hover:text-accent-400" data-value="< €10.000">&lt; &euro;10.000</button>
                  <button type="button" class="chip-btn px-4 py-2 rounded-full border-2 border-secondary-200 text-secondary-500 font-heading font-semibold text-xs transition-all duration-300 hover:border-accent-400 hover:text-accent-400" data-value="€10.000 - €25.000">&euro;10.000 - &euro;25.000</button>
                  <button type="button" class="chip-btn px-4 py-2 rounded-full border-2 border-secondary-200 text-secondary-500 font-heading font-semibold text-xs transition-all duration-300 hover:border-accent-400 hover:text-accent-400" data-value="€25.000 - €50.000">&euro;25.000 - &euro;50.000</button>
